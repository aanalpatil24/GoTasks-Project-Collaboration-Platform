# GoTasks.sys - Environment Variables Template

# 1. Django Core Settings
# Generate a new secret key for production (e.g., using `python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'`)
SECRET_KEY=django-insecure-dummy-key-for-local-dev-only

# Set to False in production!
DEBUG=True

# Comma-separated list of allowed hostnames (e.g., localhost,127.0.0.1,gotasks.sys)
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# 2. PostgreSQL Database Configuration
# These exact keys are read by both docker-compose.yml and Django settings.py
DB_NAME=gotasks_db
DB_USER=gotasks_admin
DB_PASSWORD=super_secure_password_here
DB_HOST=db       # Must match the service name in docker-compose.yml
DB_PORT=5432

# 3. Redis / Django Channels (WebSockets)
REDIS_HOST=redis # Must match the service name in docker-compose.yml
REDIS_PORT=6379

# 4. Frontend / Vite Settings
# Vite requires environment variables to be prefixed with VITE_ to be exposed to the browser
VITE_API_BASE_URL=http://localhost/api
VITE_WS_BASE_URL=ws://localhost/ws

# 5. Security & Authentication (Optional/Production)

# JWT Signature settings
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
